# Environments: "local" uses SQLite; anything else (e.g. "development") uses Supabase PostgreSQL
ENVIRONMENT=local

# SQLite (local only)
DATABASE_URL=sqlite+aiosqlite:///./dobby.db

# Supabase — required for non-local environments; safe to fill in locally too
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
# Paste the Supabase connection string as-is; postgresql:// is auto-converted to postgresql+asyncpg://
DATABASE_URL_PROD=postgresql://user:password@db.your-project.supabase.co:5432/postgres

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# App
MAX_USERS=15
ADMIN_EMAILS=admin@example.com

# CORS — comma-separated. In production set to your Railway frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
